<?xml version="1.0" encoding="UTF-8"?>
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>Partner Central Chat Agent User</label>
    <description>Grants access to the Partner Central Chat Agent feature, including custom objects, platform event subscription, and configuration metadata.</description>
    <hasActivationRequired>false</hasActivationRequired>

    <!-- Apex Class Access -->
    <classAccesses>
        <apexClass>ChatAgentController</apexClass>
        <enabled>true</enabled>
    </classAccesses>

    <!-- Object Permissions -->
    <objectPermissions>
        <object>Audit_Log__c</object>
        <allowCreate>true</allowCreate>
        <allowRead>true</allowRead>
        <allowEdit>true</allowEdit>
        <allowDelete>false</allowDelete>
        <viewAllRecords>false</viewAllRecords>
        <modifyAllRecords>false</modifyAllRecords>
    </objectPermissions>
    <objectPermissions>
        <object>Pending_Write_Operation__c</object>
        <allowCreate>true</allowCreate>
        <allowRead>true</allowRead>
        <allowEdit>true</allowEdit>
        <allowDelete>false</allowDelete>
